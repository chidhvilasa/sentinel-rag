# Sentinel-RAG Configuration

# =============================================================================
# LLM SETTINGS (Ollama)
# =============================================================================
LLM_MODEL=llama3:8b
# Alternatives: mistral:7b, phi3:mini, gemma:7b
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# =============================================================================
# SENTINEL MODEL (Detection)
# =============================================================================
SENTINEL_MODEL=microsoft/deberta-v3-small
SENTINEL_THRESHOLD=0.7
# Threshold for classifying text as "imperative/command"
# Higher = fewer false positives, more missed attacks
# Lower = catches more attacks, but may flag safe content

# =============================================================================
# VECTOR DATABASE (ChromaDB)
# =============================================================================
CHROMA_PERSIST_DIR=./data/embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# =============================================================================
# RAG SETTINGS
# =============================================================================
TOP_K_RESULTS=5
# Number of chunks to retrieve per query

# =============================================================================
# EVALUATION
# =============================================================================
ATTACK_DATASET_PATH=./data/poisoned
CLEAN_DATASET_PATH=./data/clean
RESULTS_OUTPUT_PATH=./results

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=./logs/sentinel.log
